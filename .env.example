DATABASE_URL=postgres://postgres:postgres@localhost:5432/whatsapp_sum
DATA_DIR=./data

# Multi-tenancy (feature 019 — tenancy foundation). Tenant data is isolated via
# Postgres row-level security, enforced only when the app connects as a NON-superuser
# role. DATABASE_URL above is the owner/admin connection used by migrations.
#
# APP_DATABASE_URL: the app-runtime connection as the restricted `catchup_app` role
# (created by migration 023). When UNSET it falls back to DATABASE_URL (owner), which
# bypasses RLS — fine for local single-tenant dev. Point it at catchup_app to enforce
# RLS in a multi-tenant deployment. (Set a strong password via ALTER ROLE on the box.)
# APP_DATABASE_URL=postgres://catchup_app:CHANGE_ME@localhost:5432/whatsapp_sum
#
# DEFAULT_TENANT_ID: the tenant that owns all data predating multi-tenancy. The existing
# single-user deployment runs as this tenant with no other configuration.
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# Transcription (US3) — runs locally; nothing leaves the machine.
# Path to a Python interpreter with faster-whisper installed (see quickstart).
TRANSCRIPTION_PYTHON=./.venv/bin/python
TRANSCRIPTION_MODEL=ivrit-ai/whisper-large-v3-turbo-ct2
FFMPEG_PATH=ffmpeg

# Summarization (US4) — runs locally via Ollama; nothing leaves the machine.
# Start Ollama (`ollama serve`) and pull the model (`ollama pull gemma4:26b`).
OLLAMA_HOST=http://localhost:11434
SUMMARY_MODEL=gemma4:26b
# num_ctx MUST be raised — Ollama defaults to 2048, which truncates the chat.
SUMMARY_NUM_CTX=32768
# Max estimated input tokens before a selection is rejected as too large.
SUMMARY_TOKEN_BUDGET=24000
# Sampling for the summary model. Defaults tuned for richer, fuller summaries.
# (Lower temperature / higher repeat_penalty make summaries terser.)
SUMMARY_TEMPERATURE=0.7
SUMMARY_REPEAT_PENALTY=1.1
# Max tokens generated per summary — a generous cap so output is never truncated.
SUMMARY_NUM_PREDICT=4096

# Vision / media understanding (features 007 + 010) — local via Ollama.
# Image + video captioning. Defaults route to gemma4:26b (same model as summaries →
# one resident model; better Hebrew OCR + multi-frame video than qwen2.5vl).
# Benchmarked 2026-06-07 (see bench/RESULTS.md): swapping vision to qwen2.5vl 7B was
# ~34% slower (≈7× on video) AND worse Hebrew on this hardware. Do not re-attempt the swap.
# think:false is sent automatically so the reasoning model doesn't return empty captions.
VISION_MODEL=gemma4:26b
# Video may use a different model than images; defaults to VISION_MODEL if unset.
VISION_VIDEO_MODEL=gemma4:26b
# Frame sampling for video: ~1fps, capped for memory.
VISION_VIDEO_FPS=1
VISION_VIDEO_MAX_FRAMES=8
VISION_MAX_VIDEO_MB=25
# Context window for the vision model (large num_ctx blows up KV-cache memory).
VISION_NUM_CTX=8192

# Web UI (feature 002) — local only; `catchup serve` binds to this port.
WEB_PORT=8787

# Broker (feature 003) — RabbitMQ AMQP connection URL (runs in Docker Compose).
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Logging (feature 003) — Loki log-shipping target and pino log level.
LOKI_URL=http://localhost:3100
LOG_LEVEL=info

# Worker (feature 003) — default prefetch (concurrent jobs) per worker process.
WORKER_CONCURRENCY=1

# Live collector outbound safety. Leave false: the linked device is a passive,
# read-only observer (no messages/receipts/presence). Set true ONLY to enable sending.
WHATSAPP_ALLOW_SEND=false

# Media retention — by default, media files (voice notes, images, videos) are
# pruned from disk after a successful transcription/analysis to save space.
# Set RETAIN_MEDIA=true to keep all downloaded media files on disk.
RETAIN_MEDIA=false

# Scheduled digest (feature 011) — pre-summarizes all groups twice daily so
# opening a group feels instant. Set DIGEST_ENABLED=false to disable.
DIGEST_ENABLED=true
DIGEST_TIMES=08:00,18:00

# Ops sweep (feature 012) — twice daily, re-drives dead-lettered jobs whose failure
# was likely transient and records a status snapshot (see the "Ops Sweep (history)"
# Grafana dashboard). A job re-driven OPS_REDRIVE_CAP times that still dies is left
# dead ("flagged") instead of looping forever. Set OPS_SWEEP_ENABLED=false to disable.
OPS_SWEEP_ENABLED=true
OPS_SWEEP_TIMES=08:00,18:00
OPS_REDRIVE_CAP=2
