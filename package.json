{
  "name": "catchup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "catchup": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/web/public','dist/web/public',{recursive:true})\"",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "worker": "tsx src/workers/worker.ts",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "biome check src"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "amqplib": "^0.10.7",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-loki": "^2.3.0",
    "qrcode": "^1.5.4",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@testcontainers/postgresql": "^12.0.1",
    "@testcontainers/rabbitmq": "^12.0.1",
    "@types/amqplib": "^0.10.7",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/unzipper": "^0.10.11",
    "node-pg-migrate": "^8.0.4",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0",
    "testcontainers": "^12.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
