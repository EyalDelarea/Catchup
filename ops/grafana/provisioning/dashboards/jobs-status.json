      "title": "In-flight & pending (oldest first)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "whatsapp_pg" },
      "gridPos": { "x": 13, "y": 25, "w": 11, "h": 8 },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "whatsapp_pg" }, "format": "table", "editorMode": "code", "rawSql": "SELECT type, status, attempts, round(extract(epoch FROM now() - updated_at))::int AS age FROM job_runs WHERE status IN ('running','pending') ORDER BY updated_at ASC LIMIT 30" } ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "fieldConfig": { "defaults": { "custom": { "align": "left", "filterable": true } }, "overrides": [ { "matcher": { "id": "byName", "options": "age" }, "properties": [ { "id": "unit", "value": "s" }, { "id": "custom.align", "value": "right" } ] } ] }
    }
